<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:KrytenAssist.Avalonia.Models"
        xmlns:viewModels="clr-namespace:KrytenAssist.Avalonia.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="700"
        x:Class="KrytenAssist.Avalonia.MainWindow"
        Title="KrytenAssist.Avalonia"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        x:DataType="viewModels:MainWindowViewModel">
    <Grid>
        <Grid RowDefinitions="Auto,*"
              Margin="20"
              RowSpacing="12">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="Kryten Assist"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Text="Offline prompt templates and AI conversation"
                               FontSize="13"
                               Opacity="0.7" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="2*,3*"
                  ColumnSpacing="12">

                <Border Grid.Column="0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                          RowSpacing="10">
                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <TextBlock Text="Prompt Library"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="New Prompt"
                                    Command="{Binding OpenPromptEditorCommand}" />
                        </Grid>

                        <TextBox Grid.Row="1"
                                 PlaceholderText="Search prompts..."
                                 Text="{Binding SearchText}" />

                        <Border Grid.Row="2"
                                IsVisible="{Binding HasEmbeddingStatusMessage}"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock Text="{Binding EmbeddingStatusMessage}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <TextBlock Grid.Row="3"
                                   Text="No prompts found."
                                   IsVisible="{Binding HasNoSearchResults}"
                                   HorizontalAlignment="Center" />

                        <ScrollViewer Grid.Row="4"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FilteredPromptCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:PromptCardModel">
                                        <Border Padding="10"
                                                Margin="0,0,0,6"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Category}"
                                                           FontSize="12"
                                                           Opacity="0.7" />
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto"
                          RowSpacing="12">
                        <TextBlock Grid.Row="0"
                                   Text="AI Conversation"
                                   FontSize="18"
                                   FontWeight="SemiBold" />

                        <ListBox x:Name="ConversationList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding ConversationHistory}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:ConversationMessage">
                                    <Border BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Role}"
                                                       FontWeight="Bold"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding ConversationErrorMessage}"
                                   IsVisible="{Binding HasConversationError}"
                                   TextWrapping="Wrap" />

                        <TextBox x:Name="ConversationInputBox"
                                 Grid.Row="3"
                                 AcceptsReturn="True"
                                 MinHeight="80"
                                 MaxHeight="160"
                                 TextWrapping="Wrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PlaceholderText="Ask Kryten..."
                                 Text="{Binding ConversationInput, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Grid.Row="4"
                              ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                              ColumnSpacing="8">
                            <Button Content="Send"
                                    MinWidth="72"
                                    Command="{Binding SendMessageCommand}" />

                            <Button Grid.Column="1"
                                    Content="Cancel"
                                    MinWidth="72"
                                    Command="{Binding CancelConversationCommand}" />
                            <Button Grid.Column="2"
                                    Content="Clear Conversation"
                                    Command="{Binding ClearConversationCommand}" />

                            <TextBlock Grid.Column="4"
                                       Text="Thinking..."
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsConversationBusy}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border IsVisible="{Binding IsPromptEditorOpen}"
                Background="#99000000">
            <Border Width="620"
                    MaxHeight="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <Grid RowDefinitions="Auto,*,Auto"
                      RowSpacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Create prompt template"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="8">
                            <TextBox PlaceholderText="Title"
                                     Text="{Binding NewTitle}" />

                            <TextBox PlaceholderText="Category"
                                     Text="{Binding NewCategory}" />

                            <TextBlock Text="Category suggestions"
                                       FontSize="12"
                                       Opacity="0.7" />

                            <ItemsControl x:Name="CategorySuggestions"
                                          ItemsSource="{Binding Categories}"
                                          Tag="{Binding SelectCategoryCommand}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Button Content="{Binding}"
                                                Command="{Binding #CategorySuggestions.Tag}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,8,8"
                                                Padding="8,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBox PlaceholderText="Description"
                                     Text="{Binding NewDescription}" />

                            <TextBox PlaceholderText="Prompt text"
                                     Text="{Binding NewPromptText}"
                                     AcceptsReturn="True"
                                     MinHeight="100"
                                     TextWrapping="Wrap" />

                            <TextBox PlaceholderText="Tags, comma separated"
                                     Text="{Binding NewTags}" />

                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Content="Save"
                                MinWidth="72"
                                Command="{Binding SaveCommand}" />
                        <Button Content="Cancel"
                                MinWidth="72"
                                Command="{Binding ClosePromptEditorCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
