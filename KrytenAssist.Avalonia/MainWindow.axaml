<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:navigationModels="clr-namespace:KrytenAssist.Avalonia.Navigation.Models"
        xmlns:viewModels="clr-namespace:KrytenAssist.Avalonia.ViewModels"
        xmlns:views="clr-namespace:KrytenAssist.Avalonia.Views"
        mc:Ignorable="d"
        d:DesignWidth="1100"
        d:DesignHeight="700"
        x:Class="KrytenAssist.Avalonia.MainWindow"
        Title="Kryten Assist"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        x:DataType="viewModels:ShellViewModel">
    <Grid RowDefinitions="Auto,*"
          Margin="20"
          RowSpacing="12">
        <Border Grid.Row="0"
                Classes="header-surface"
                Padding="12,9">
            <StackPanel Spacing="1">
                <TextBlock Text="Kryten Assist"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Text="Making Future Robin's Life Easier"
                           Classes="secondary-text"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="210,*"
              ColumnSpacing="12">
            <Border Grid.Column="0"
                    Classes="navigation-surface"
                    Padding="10">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="8">
                    <TextBlock Text="Navigation"
                               Classes="section-heading"
                               Margin="6,2" />
                    <ListBox x:Name="NavigationList"
                             Grid.Row="1"
                             Classes="navigation-list"
                             ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNavigationItem, Mode=OneWay}"
                             SelectionChanged="NavigationList_OnSelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="navigationModels:NavigationItem">
                                <TextBlock Text="{Binding Title}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <views:DashboardView IsVisible="{Binding IsDashboardSelected}" />
                <Grid IsVisible="{Binding IsAssistantSelected}">
                    <views:AssistantWorkspaceView DataContext="{Binding AssistantWorkspace}" />
                </Grid>
                <Grid IsVisible="{Binding IsCruiseOfTheWeekSelected}">
                    <views:CruiseOfTheWeekView DataContext="{Binding CruiseOfTheWeek}" />
                </Grid>
                <views:SkillDetailsView IsVisible="{Binding IsGenericSkillSelected}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
