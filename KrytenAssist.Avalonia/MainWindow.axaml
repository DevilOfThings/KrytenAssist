<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:KrytenAssist.Avalonia.Models"
        xmlns:viewModels="clr-namespace:KrytenAssist.Avalonia.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="KrytenAssist.Avalonia.MainWindow"
        Title="KrytenAssist.Avalonia"
        x:DataType="viewModels:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*" Margin="24" RowSpacing="16">
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Kryten Assist"
                       FontSize="28"
                       FontWeight="Bold" />
            <TextBlock Text="Offline prompt cards"
                       FontSize="14"
                       Opacity="0.7" />
        </StackPanel>

        <Border Grid.Row="1"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <ItemsControl ItemsSource="{Binding PromptCards}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:PromptCardModel">
                        <Border Padding="12"
                                Margin="0,0,0,8"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Category}"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <TextBlock Text="{Binding Description}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
